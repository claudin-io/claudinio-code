{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claudinio Code",
  "version": "0.1.1",
  "identifier": "io.claudin.code",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claudinio Code",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "backgroundColor": "#141210"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "models/LateOn-Code-edge/*": "models/LateOn-Code-edge/"
    }
  }
}
